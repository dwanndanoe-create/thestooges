-- Activeer de UUID extensie (standaard in Supabase)
create extension if not exists "uuid-ossp";

-- 1. PROFILES TABEL (Gekoppeld aan Supabase Auth)
create table public.profiles (
  id uuid references auth.users on delete cascade primary key,
  full_name text not null,
  location text not null,
  role text check (role in ('worker', 'employer')) not null,
  created_at timestamp with time zone default timezone('utc'::text, now()) not null
);

-- 2. JOBS TABEL
create table public.jobs (
  id uuid default gen_random_uuid() primary key,
  employer_id uuid references public.profiles(id) on delete cascade not null,
  title text not null,
  location text not null,
  skills text[] not null, -- Slaat skills op als een nette array van tekst
  job_when text not null,
  pay numeric(10, 2) not null,
  description text not null,
  posted_by text not null, -- Voor snelle weergave van de naam
  created_at timestamp with time zone default timezone('utc'::text, now()) not null
);

-- Zet Row Level Security (RLS) aan voor veiligheid
alter table public.profiles enable row level security;
alter table public.jobs enable row level security;

-- Maak RLS Policies (Iedereen mag lezen, ingelogde gebruikers mogen schrijven)
create policy "Profielen zijn openbaar leesbaar" on public.profiles for select using (true);
create policy "Gebruikers kunnen eigen profiel aanmaken/aanpassen" on public.profiles for all using (auth.uid() = id);

create policy "Jobs zijn openbaar leesbaar" on public.jobs for select using (true);
create policy "Ingelogde gebruikers kunnen jobs plaatsen" on public.jobs for insert with check (auth.uid() = employer_id);
create policy "Werkgevers kunnen eigen jobs aanpassen of verwijderen" on public.jobs for all using (auth.uid() = employer_id);